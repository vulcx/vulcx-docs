{
  "asyncapi": "3.0.0",
  "info": {
    "title": "Argyros Stream API",
    "version": "1.0.0",
    "description": "Real-time swap quote stream over WebSocket. Subscribe to token pairs and receive a quote push whenever the price materially changes."
  },
  "servers": {
    "production": {
      "host": "api.argyros.xyz",
      "protocol": "wss",
      "description": "Production WebSocket server. Requires an API key as a `?key=` query parameter on the connection URL (e.g. `wss://api.argyros.xyz/api/v1/stream?key=argy_...`) — browsers can't set custom headers on a WebSocket handshake, so this is the only way to authenticate. A missing or invalid key is rejected before the upgrade completes.",
      "security": [{ "$ref": "#/components/securitySchemes/ApiKeyQuery" }]
    }
  },
  "channels": {
    "stream": {
      "address": "/api/v1/stream",
      "description": "Subscribe to live swap quotes for one or more token pairs. Send a `subscribe` message to start receiving quote pushes; send `unsubscribe` to stop. Supports up to 256 subscriptions per connection.",
      "messages": {
        "subscribe": {
          "name": "Subscribe",
          "title": "Subscribe",
          "summary": "Subscribe to live quote updates for one or more token pairs.",
          "contentType": "application/json",
          "payload": {
            "type": "object",
            "required": ["op", "pairs"],
            "properties": {
              "op": {
                "type": "string",
                "const": "subscribe",
                "description": "Operation type.",
                "example": "subscribe"
              },
              "pairs": {
                "type": "array",
                "description": "Token pairs to subscribe to.",
                "items": { "$ref": "#/components/schemas/PairRequest" }
              }
            }
          },
          "examples": [
            {
              "name": "Subscribe to a pair",
              "payload": {
                "op": "subscribe",
                "pairs": [
                  {
                    "in": "So11111111111111111111111111111111111111112",
                    "out": "uSd2czE61Evaf76RNbq4KPpXnkiL3irdzgLFUMe3NoG",
                    "amount": "50000000",
                    "exactIn": true
                  }
                ]
              }
            }
          ]
        },
        "unsubscribe": {
          "name": "Unsubscribe",
          "title": "Unsubscribe",
          "summary": "Stop receiving quote updates for one or more token pairs.",
          "contentType": "application/json",
          "payload": {
            "type": "object",
            "required": ["op", "pairs"],
            "properties": {
              "op": {
                "type": "string",
                "const": "unsubscribe",
                "description": "Operation type.",
                "example": "unsubscribe"
              },
              "pairs": {
                "type": "array",
                "description": "Token pairs to unsubscribe from.",
                "items": { "$ref": "#/components/schemas/PairRequest" }
              }
            }
          }
        },
        "quotePush": {
          "name": "QuotePush",
          "title": "Quote push",
          "summary": "Pushed by the server when a subscribed pair's price materially changes.",
          "contentType": "application/json",
          "payload": {
            "type": "object",
            "required": ["type", "in", "out", "amount", "amountOut", "priceImpactBps", "hops", "slot"],
            "properties": {
              "type": {
                "type": "string",
                "const": "quote",
                "example": "quote"
              },
              "in": {
                "type": "string",
                "description": "Input token mint.",
                "example": "So11111111111111111111111111111111111111112"
              },
              "out": {
                "type": "string",
                "description": "Output token mint.",
                "example": "uSd2czE61Evaf76RNbq4KPpXnkiL3irdzgLFUMe3NoG"
              },
              "amount": {
                "type": "string",
                "description": "The subscribed amount in smallest token units.",
                "example": "50000000"
              },
              "amountOut": {
                "type": "string",
                "description": "Estimated output amount in smallest token units.",
                "example": "452"
              },
              "priceImpactBps": {
                "type": "integer",
                "description": "Price impact in basis points.",
                "example": 0
              },
              "hops": {
                "type": "integer",
                "description": "Number of hops in the route. 1 = direct, 2+ = multi-hop.",
                "example": 1
              },
              "slot": {
                "type": "integer",
                "description": "Fogo slot the quote was computed at.",
                "example": 587964937
              }
            }
          },
          "examples": [
            {
              "name": "Quote push",
              "payload": {
                "type": "quote",
                "in": "So11111111111111111111111111111111111111112",
                "out": "uSd2czE61Evaf76RNbq4KPpXnkiL3irdzgLFUMe3NoG",
                "amount": "50000000",
                "amountOut": "452",
                "priceImpactBps": 0,
                "hops": 1,
                "slot": 587964937
              }
            }
          ]
        },
        "ack": {
          "name": "Ack",
          "title": "Acknowledgement",
          "summary": "Server acknowledgement for subscribe/unsubscribe, or an error response.",
          "contentType": "application/json",
          "payload": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["subscribed", "unsubscribed", "error"],
                "description": "Acknowledgement type.",
                "example": "subscribed"
              },
              "count": {
                "type": "integer",
                "description": "Number of pairs accepted. Invalid or duplicate pairs are skipped and not counted.",
                "example": 1
              },
              "message": {
                "type": "string",
                "description": "Error description. Present only when `type` is `error`.",
                "example": "unknown op"
              }
            }
          },
          "examples": [
            {
              "name": "Subscribed ack",
              "payload": { "type": "subscribed", "count": 1 }
            },
            {
              "name": "Error",
              "payload": { "type": "error", "message": "unknown op" }
            }
          ]
        }
      }
    }
  },
  "operations": {
    "sendMessages": {
      "action": "send",
      "channel": { "$ref": "#/channels/stream" },
      "summary": "Subscribe or unsubscribe to pair quote streams",
      "messages": [
        { "$ref": "#/channels/stream/messages/subscribe" },
        { "$ref": "#/channels/stream/messages/unsubscribe" }
      ]
    },
    "receiveMessages": {
      "action": "receive",
      "channel": { "$ref": "#/channels/stream" },
      "summary": "Receive quote pushes and acknowledgements",
      "messages": [
        { "$ref": "#/channels/stream/messages/quotePush" },
        { "$ref": "#/channels/stream/messages/ack" }
      ]
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyQuery": {
        "type": "httpApiKey",
        "in": "query",
        "name": "key",
        "description": "API key as a `?key=argy_...` query parameter. Required — this is the only auth option for the WebSocket stream, since browsers can't set custom headers on a WS handshake."
      }
    },
    "schemas": {
      "PairRequest": {
        "type": "object",
        "required": ["in", "out", "amount", "exactIn"],
        "description": "A token pair subscription. The subscription key is the full (in, out, amount, exactIn) tuple — two entries differing only in amount are distinct streams.",
        "properties": {
          "in": {
            "type": "string",
            "description": "Input token mint address (Solana base58 public key).",
            "example": "So11111111111111111111111111111111111111112"
          },
          "out": {
            "type": "string",
            "description": "Output token mint address (Solana base58 public key).",
            "example": "uSd2czE61Evaf76RNbq4KPpXnkiL3irdzgLFUMe3NoG"
          },
          "amount": {
            "type": "string",
            "description": "Amount in smallest token units, as a string. For SOL (9 decimals): 1000000000 = 1 SOL.",
            "example": "50000000"
          },
          "exactIn": {
            "type": "boolean",
            "description": "`true` quotes `amount` as the exact input (ExactIn). `false` treats it as the exact desired output (ExactOut).",
            "example": true
          }
        }
      }
    }
  }
}
